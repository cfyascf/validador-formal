digraph MTRecursivaPalindromo {
  rankdir=LR;
  node [shape=circle];
  start [shape=point];
  q_accept [shape=doublecircle];
  q_reject [shape=doublecircle];

  start -> q_start;
  q_start -> q_start [label="X/X,R ; Y/Y,R"];
  q_start -> q_seek_right_0 [label="0/X,R"];
  q_start -> q_seek_right_1 [label="1/Y,R"];
  q_start -> q_accept [label="B/B,S"];

  q_seek_right_0 -> q_seek_right_0 [label="0,1,X,Y / mesma coisa,R"];
  q_seek_right_0 -> q_check_0 [label="B/B,L"];
  q_seek_right_1 -> q_seek_right_1 [label="0,1,X,Y / mesma coisa,R"];
  q_seek_right_1 -> q_check_1 [label="B/B,L"];

  q_check_0 -> q_check_0 [label="X,Y / mesma coisa,L"];
  q_check_0 -> q_return_left [label="0/X,L"];
  q_check_0 -> q_accept [label="B/B,S"];
  q_check_0 -> q_reject [label="1/1,S"];

  q_check_1 -> q_check_1 [label="X,Y / mesma coisa,L"];
  q_check_1 -> q_return_left [label="1/Y,L"];
  q_check_1 -> q_accept [label="B/B,S"];
  q_check_1 -> q_reject [label="0/0,S"];

  q_return_left -> q_return_left [label="0,1,X,Y / mesma coisa,L"];
  q_return_left -> q_start [label="B/B,R"];
}